{
  "name": "ailearn",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "dev:web": "turbo run dev --filter=web",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types",
    "db:generate": "turbo run db:generate --filter=@ailearn/database",
    "db:push": "turbo run db:push --filter=@ailearn/database",
    "db:seed": "turbo run db:seed --filter=@ailearn/database"
  },
  "devDependencies": {
    "prettier": "^3.7.4",
    "turbo": "^2.9.17",
    "typescript": "5.9.2"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "npm@11.11.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}

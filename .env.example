# ============================================================
# AILearn - Environment Variables
# ============================================================

# Database
DATABASE_URL="postgresql://user:password@localhost:5432/ailearn?schema=public"

# Firebase
NEXT_PUBLIC_FIREBASE_API_KEY="your-firebase-api-key"
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN="your-project.firebaseapp.com"
NEXT_PUBLIC_FIREBASE_PROJECT_ID="your-project-id"
FIREBASE_ADMIN_SERVICE_ACCOUNT='{"type":"service_account","project_id":"..."}'

# Stripe
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."

# Daily.co
DAILY_CO_API_KEY="your-daily-co-api-key"
NEXT_PUBLIC_DAILY_CO_DOMAIN="your-domain.daily.co"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"
